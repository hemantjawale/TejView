<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sleep_title"
            android:textColor="?attr/auroraTextPrimary"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="20dp" />

        <!-- Sleep Quality Card -->
        <LinearLayout
            android:id="@+id/cardSleepQuality"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/auroraSerenityDrawable"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sleep_quality"
                android:textColor="?attr/auroraTextSecondary"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tvSleepScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/aurora_primary_light"
                    android:textSize="48sp"
                    android:fontFamily="sans-serif-light"
                    tools:text="82" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="/100"
                    android:textColor="?attr/auroraTextTertiary"
                    android:textSize="16sp"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="8dp" />

                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/tvSleepHours"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?attr/auroraTextPrimary"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-medium"
                        tools:text="7h 23m" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="total sleep"
                        android:textColor="?attr/auroraTextMuted"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Sleep Phases -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/auroraCardDrawable"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sleep_phases"
                android:textColor="?attr/auroraTextSecondary"
                android:textSize="13sp"
                android:layout_marginBottom="12dp" />

            <!-- Phase bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="16dp"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <View android:id="@+id/barDeep" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="25" android:background="@color/sleep_deep" />
                <View android:id="@+id/barLight" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="35" android:background="@color/sleep_light" />
                <View android:id="@+id/barRem" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="25" android:background="@color/sleep_rem" />
                <View android:id="@+id/barAwake" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="15" android:background="@color/sleep_awake" />
            </LinearLayout>

            <!-- Phase legend -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <View android:layout_width="10dp" android:layout_height="10dp" android:background="@color/sleep_deep" />
                    <TextView android:id="@+id/tvDeepPercent" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="?attr/auroraTextTertiary" android:textSize="11sp" android:layout_marginTop="4dp" tools:text="25%" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/sleep_deep" android:textColor="?attr/auroraTextMuted" android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <View android:layout_width="10dp" android:layout_height="10dp" android:background="@color/sleep_light" />
                    <TextView android:id="@+id/tvLightPercent" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="?attr/auroraTextTertiary" android:textSize="11sp" android:layout_marginTop="4dp" tools:text="35%" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/sleep_light" android:textColor="?attr/auroraTextMuted" android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <View android:layout_width="10dp" android:layout_height="10dp" android:background="@color/sleep_rem" />
                    <TextView android:id="@+id/tvRemPercent" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="?attr/auroraTextTertiary" android:textSize="11sp" android:layout_marginTop="4dp" tools:text="25%" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/sleep_rem" android:textColor="?attr/auroraTextMuted" android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <View android:layout_width="10dp" android:layout_height="10dp" android:background="@color/sleep_awake" />
                    <TextView android:id="@+id/tvAwakePercent" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="?attr/auroraTextTertiary" android:textSize="11sp" android:layout_marginTop="4dp" tools:text="15%" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/sleep_awake" android:textColor="?attr/auroraTextMuted" android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Sleep Schedule -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/auroraCardDrawable"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sleep_schedule"
                android:textColor="?attr/auroraTextSecondary"
                android:textSize="13sp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌙" android:textSize="24sp" />
                    <TextView android:id="@+id/tvBedtime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="?attr/auroraTextPrimary" android:textSize="18sp" android:fontFamily="sans-serif-medium" android:layout_marginTop="4dp" tools:text="22:30" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bedtime" android:textColor="?attr/auroraTextMuted" android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="☀️" android:textSize="24sp" />
                    <TextView android:id="@+id/tvWakeTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="?attr/auroraTextPrimary" android:textSize="18sp" android:fontFamily="sans-serif-medium" android:layout_marginTop="4dp" tools:text="06:00" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Wake up" android:textColor="?attr/auroraTextMuted" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Sleep tracking button -->
        <TextView
            android:id="@+id/btnStartSleepTracking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_button_primary"
            android:gravity="center"
            android:padding="14dp"
            android:text="@string/sleep_start_tracking"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Weekly Pattern -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sleep_weekly"
            android:textColor="?attr/auroraTextPrimary"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/auroraCardDrawable"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:orientation="horizontal"
                android:gravity="bottom|center_horizontal">

                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                    <View android:id="@+id/barMon" android:layout_width="16dp" android:layout_height="50dp" android:background="@color/sleep_light" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="M" android:textColor="?attr/auroraTextMuted" android:textSize="10sp" android:layout_marginTop="4dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                    <View android:id="@+id/barTue" android:layout_width="16dp" android:layout_height="60dp" android:background="@color/sleep_light" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T" android:textColor="?attr/auroraTextMuted" android:textSize="10sp" android:layout_marginTop="4dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                    <View android:id="@+id/barWed" android:layout_width="16dp" android:layout_height="45dp" android:background="@color/sleep_light" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="W" android:textColor="?attr/auroraTextMuted" android:textSize="10sp" android:layout_marginTop="4dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                    <View android:id="@+id/barThu" android:layout_width="16dp" android:layout_height="55dp" android:background="@color/sleep_light" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T" android:textColor="?attr/auroraTextMuted" android:textSize="10sp" android:layout_marginTop="4dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                    <View android:id="@+id/barFri" android:layout_width="16dp" android:layout_height="65dp" android:background="@color/aurora_primary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="F" android:textColor="?attr/auroraTextMuted" android:textSize="10sp" android:layout_marginTop="4dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                    <View android:id="@+id/barSat" android:layout_width="16dp" android:layout_height="70dp" android:background="@color/sleep_light" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S" android:textColor="?attr/auroraTextMuted" android:textSize="10sp" android:layout_marginTop="4dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                    <View android:id="@+id/barSun" android:layout_width="16dp" android:layout_height="58dp" android:background="@color/sleep_light" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S" android:textColor="?attr/auroraTextMuted" android:textSize="10sp" android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvWeeklyAverage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/auroraTextTertiary"
                android:textSize="12sp"
                android:layout_marginTop="12dp"
                tools:text="Weekly avg: 7h 12m" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
