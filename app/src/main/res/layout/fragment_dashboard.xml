<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp">

        <!-- Header + Theme Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/auroraTextSecondary"
                    android:textSize="14sp"
                    tools:text="Good Morning" />

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/auroraTextPrimary"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="2dp"
                    tools:text="Monday, April 14" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <FrameLayout
                    android:id="@+id/btnSettings"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/auroraCardDrawable"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackgroundBorderless"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="⚙️"
                        android:textSize="20sp" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/btnThemeToggle"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/auroraCardDrawable"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackgroundBorderless">

                    <TextView
                        android:id="@+id/tvThemeIcon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="☀️"
                        android:textSize="20sp" />
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Serenity Score -->
        <LinearLayout
            android:id="@+id/cardSerenity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/auroraSerenityDrawable"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_serenity"
                android:textColor="?attr/auroraTextSecondary"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tvSerenityScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/aurora_primary_light"
                    android:textSize="56sp"
                    android:fontFamily="sans-serif-light"
                    tools:text="87" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/100"
                        android:textColor="?attr/auroraTextTertiary"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/tvSerenityStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip_green"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="3dp"
                        android:textColor="@color/aurora_success"
                        android:textSize="11sp"
                        tools:text="Excellent" />
                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <com.example.tejview.ui.views.AuroraProgressRing
                    android:id="@+id/serenityRing"
                    android:layout_width="80dp"
                    android:layout_height="80dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Today's Vitals -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dashboard_today"
            android:textColor="?attr/auroraTextPrimary"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="12dp" />

        <!-- BPM + SpO2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/cardHeartRate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="?attr/auroraCardDrawable"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginEnd="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/heartPulseDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_glow_dot_violet" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/desc_heart_rate"
                        android:textColor="?attr/auroraTextTertiary"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"
                        android:layout_marginStart="6dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvHeartRate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/health_heart"
                    android:textSize="36sp"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginTop="8dp"
                    tools:text="72" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/metric_bpm"
                    android:textColor="?attr/auroraTextMuted"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardSpO2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="?attr/auroraCardDrawable"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginStart="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_glow_dot_violet" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/desc_blood_oxygen"
                        android:textColor="?attr/auroraTextTertiary"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"
                        android:layout_marginStart="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/tvSpO2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/aurora_success"
                        android:textSize="36sp"
                        android:fontFamily="sans-serif-light"
                        tools:text="98" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/metric_percent"
                        android:textColor="@color/aurora_success"
                        android:textSize="18sp"
                        android:layout_marginStart="2dp"
                        android:layout_marginBottom="6dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/metric_spo2"
                    android:textColor="?attr/auroraTextMuted"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Steps + Calories -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/cardSteps"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="?attr/auroraCardDrawable"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/desc_daily_steps"
                    android:textColor="?attr/auroraTextTertiary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/tvSteps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/health_steps"
                    android:textSize="32sp"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginTop="8dp"
                    tools:text="8,432" />

                <ProgressBar
                    android:id="@+id/progressSteps"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="8dp"
                    android:max="10000"
                    android:progressDrawable="@drawable/progress_aurora_violet"
                    tools:progress="8432" />

                <TextView
                    android:id="@+id/tvStepsGoal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/auroraTextMuted"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    tools:text="/ 10,000 goal" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardCalories"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="?attr/auroraCardDrawable"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/desc_calories_burned"
                    android:textColor="?attr/auroraTextTertiary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/tvCalories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/health_calories"
                    android:textSize="32sp"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginTop="8dp"
                    tools:text="1,847" />

                <ProgressBar
                    android:id="@+id/progressCalories"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="8dp"
                    android:max="2500"
                    android:progressDrawable="@drawable/progress_aurora_amber"
                    tools:progress="1847" />

                <TextView
                    android:id="@+id/tvCaloriesGoal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/auroraTextMuted"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    tools:text="/ 2,500 goal" />
            </LinearLayout>
        </LinearLayout>

        <!-- Active Minutes + Water -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="?attr/auroraCardDrawable"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/metric_active_min"
                    android:textColor="?attr/auroraTextTertiary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/tvActiveMinutes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/aurora_success"
                    android:textSize="32sp"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginTop="8dp"
                    tools:text="42" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="minutes"
                    android:textColor="?attr/auroraTextMuted"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardWater"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="?attr/auroraCardDrawable"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/health_hydration"
                    android:textColor="?attr/auroraTextTertiary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/tvWaterCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/health_water"
                        android:textSize="32sp"
                        android:fontFamily="sans-serif-light"
                        tools:text="6" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/8"
                        android:textColor="?attr/auroraTextMuted"
                        android:textSize="16sp"
                        android:layout_marginStart="2dp"
                        android:layout_marginBottom="4dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/metric_glasses"
                    android:textColor="?attr/auroraTextMuted"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Sleep Summary -->
        <LinearLayout
            android:id="@+id/cardSleepSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/auroraCardDrawable"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Last Night\'s Sleep"
                    android:textColor="?attr/auroraTextTertiary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/tvSleepDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/aurora_primary_light"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginTop="4dp"
                    tools:text="7h 23m" />

                <TextView
                    android:id="@+id/tvSleepQuality"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_violet"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="3dp"
                    android:textColor="@color/aurora_primary"
                    android:textSize="11sp"
                    android:layout_marginTop="6dp"
                    tools:text="Good Quality" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="100dp"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="bottom|center_horizontal">

                <View android:layout_width="8dp" android:layout_height="20dp" android:background="@color/sleep_deep" android:layout_marginEnd="3dp" />
                <View android:layout_width="8dp" android:layout_height="35dp" android:background="@color/sleep_light" android:layout_marginEnd="3dp" />
                <View android:layout_width="8dp" android:layout_height="28dp" android:background="@color/sleep_rem" android:layout_marginEnd="3dp" />
                <View android:layout_width="8dp" android:layout_height="40dp" android:background="@color/sleep_light" android:layout_marginEnd="3dp" />
                <View android:layout_width="8dp" android:layout_height="15dp" android:background="@color/sleep_deep" android:layout_marginEnd="3dp" />
                <View android:layout_width="8dp" android:layout_height="25dp" android:background="@color/sleep_rem" />
            </LinearLayout>
        </LinearLayout>

        <!-- Protein -->
        <LinearLayout
            android:id="@+id/cardProtein"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/auroraCardDrawable"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Protein Intake"
                    android:textColor="?attr/auroraTextTertiary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/tvProteinGoal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/auroraTextMuted"
                    android:textSize="12sp"
                    tools:text="/ 120g goal" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tvProteinValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/health_protein"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-light"
                    tools:text="78g" />

                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                <TextView
                    android:id="@+id/btnAddProtein"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_button_outline"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="+ Add"
                    android:textColor="@color/aurora_primary"
                    android:textSize="13sp" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressProtein"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="12dp"
                android:max="120"
                android:progressDrawable="@drawable/progress_aurora_pink"
                tools:progress="78" />
        </LinearLayout>

        <!-- Quick Actions -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick Actions"
            android:textColor="?attr/auroraTextPrimary"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="12dp"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/btnQuickWater"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="?attr/auroraCardDrawable"
                android:gravity="center"
                android:padding="14dp"
                android:text="💧 Water"
                android:textColor="@color/health_water"
                android:textSize="13sp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/btnQuickExercise"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="?attr/auroraCardDrawable"
                android:gravity="center"
                android:padding="14dp"
                android:text="🏃 Exercise"
                android:textColor="@color/aurora_success"
                android:textSize="13sp"
                android:layout_marginHorizontal="3dp" />

            <TextView
                android:id="@+id/btnQuickMood"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="?attr/auroraCardDrawable"
                android:gravity="center"
                android:padding="14dp"
                android:text="🧘 Mood"
                android:textColor="@color/aurora_primary"
                android:textSize="13sp"
                android:layout_marginStart="6dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
