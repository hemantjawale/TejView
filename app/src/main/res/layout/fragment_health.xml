<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/health_title"
            android:textColor="?attr/auroraTextPrimary"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="20dp" />

        <!-- Vitals -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/cardBP"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="?attr/auroraCardDrawable"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/health_blood_pressure"
                    android:textColor="?attr/auroraTextTertiary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/tvBloodPressure"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/health_heart"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginTop="8dp"
                    tools:text="120/80" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="mmHg"
                    android:textColor="?attr/auroraTextMuted"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardHR"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="?attr/auroraCardDrawable"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/desc_heart_rate"
                    android:textColor="?attr/auroraTextTertiary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/tvHR"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/health_heart"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginTop="8dp"
                    tools:text="72" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="bpm"
                    android:textColor="?attr/auroraTextMuted"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Hydration -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/auroraCardDrawable"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/health_hydration"
                android:textColor="?attr/auroraTextSecondary"
                android:textSize="13sp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/layoutWaterDots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <View android:id="@+id/dot1" android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/bg_water_dot_empty" android:layout_margin="4dp" />
                <View android:id="@+id/dot2" android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/bg_water_dot_empty" android:layout_margin="4dp" />
                <View android:id="@+id/dot3" android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/bg_water_dot_empty" android:layout_margin="4dp" />
                <View android:id="@+id/dot4" android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/bg_water_dot_empty" android:layout_margin="4dp" />
                <View android:id="@+id/dot5" android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/bg_water_dot_empty" android:layout_margin="4dp" />
                <View android:id="@+id/dot6" android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/bg_water_dot_empty" android:layout_margin="4dp" />
                <View android:id="@+id/dot7" android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/bg_water_dot_empty" android:layout_margin="4dp" />
                <View android:id="@+id/dot8" android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/bg_water_dot_empty" android:layout_margin="4dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnAddWater"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button_outline"
                android:gravity="center"
                android:padding="10dp"
                android:text="💧 Add Glass"
                android:textColor="@color/health_water"
                android:textSize="13sp"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <!-- Protein -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/auroraCardDrawable"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/health_protein"
                    android:textColor="?attr/auroraTextSecondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvProtein"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/health_protein"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-medium"
                    tools:text="78g / 120g" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressProteinHealth"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="12dp"
                android:max="120"
                android:progressDrawable="@drawable/progress_aurora_pink"
                tools:progress="78" />
        </LinearLayout>

        <!-- Medications -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/health_medications"
            android:textColor="?attr/auroraTextPrimary"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/btnAddMedication"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/auroraCardDrawable"
            android:gravity="center"
            android:padding="14dp"
            android:text="+ Add Medication"
            android:textColor="@color/aurora_primary"
            android:textSize="13sp"
            android:layout_marginBottom="12dp" />

        <!-- Health Issues -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/health_issues"
            android:textColor="?attr/auroraTextPrimary"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/btnReportIssue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/auroraCardDrawable"
            android:gravity="center"
            android:padding="14dp"
            android:text="+ Report Health Issue"
            android:textColor="@color/aurora_warning"
            android:textSize="13sp"
            android:layout_marginBottom="16dp" />

        <!-- Health Alerts -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/health_alerts"
            android:textColor="?attr/auroraTextPrimary"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/layoutAlerts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvNoAlerts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/auroraCardDrawable"
                android:gravity="center"
                android:padding="20dp"
                android:text="✅ No active health alerts"
                android:textColor="@color/aurora_success"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
