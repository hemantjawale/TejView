<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/auroraCardDrawable"
    android:orientation="horizontal"
    android:padding="14dp"
    android:gravity="center_vertical"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/tvExerciseEmoji"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:gravity="center"
        android:textSize="20sp"
        tools:text="🏃" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="10dp">

        <TextView
            android:id="@+id/tvExerciseName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/auroraTextPrimary"
            android:textSize="14sp"
            tools:text="Running" />

        <TextView
            android:id="@+id/tvExerciseDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/auroraTextMuted"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            tools:text="32 min · 4.2 km · 285 cal" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvExerciseTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="?attr/auroraTextTertiary"
        android:textSize="11sp"
        tools:text="2h ago" />
</LinearLayout>
